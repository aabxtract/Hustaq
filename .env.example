# Local dev — copy to .env and fill in your values
ENV=local

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+234xxxxxxxxxx
# Maps to Secrets Manager key hustaq/twilio/auth_token
HUSTAQ_TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Skip Twilio signature check for local curl tests (set to 'true' only locally)
SKIP_TWILIO_VERIFY=true

# PostgreSQL (matches docker-compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hustaq
DB_USER=hustaq
DB_PASS=hustaq_local

# Redis (matches docker-compose)
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 — leave blank locally, save_media_to_s3 will skip upload
S3_BUCKET=hustaq-products-dev

# AWS — only needed if you want Secrets Manager locally (not required)
AWS_REGION=eu-west-1

# Lambda URL — used as Nomba callback (any value works locally)
LAMBDA_URL=http://localhost:8000

# Nomba sandbox
NOMBA_ENV=sandbox
# Maps to Secrets Manager keys hustaq/nomba/client_id and hustaq/nomba/client_secret
HUSTAQ_NOMBA_CLIENT_ID=your_nomba_client_id
HUSTAQ_NOMBA_CLIENT_SECRET=your_nomba_client_secret
